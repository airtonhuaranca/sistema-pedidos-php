{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/guardar.php", "dest": "/api/guardar.php" },
    { "src": "/actualizar.php", "dest": "/api/actualizar.php" },
    { "src": "/eliminar.php", "dest": "/api/eliminar.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}